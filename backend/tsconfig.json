{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",                    // ✅ 保持為 backend/src
    "types": ["jest", "node"],
    "paths": {
      "@clinic/*": ["../packages/*/src"],
      "@engine-booking/*": ["../../packages/engine-booking/src/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true                         // 只檢查型別，不輸出
  },
  "include": ["src/**/*.ts"],              // ✅ 僅包含 backend/src
  "exclude": ["node_modules"]
}