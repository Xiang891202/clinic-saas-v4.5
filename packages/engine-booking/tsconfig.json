{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    // ✅ 移除 rootDir，讓 TypeScript 自動推斷為 packages/
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "../shared/src/**/*.ts"   // ✅ 包含 shared 原始碼
  ],
  "exclude": ["src/**/*.test.ts", "node_modules"]
}